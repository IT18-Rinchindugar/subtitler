# Copy to .env and fill in real values before running docker-compose

# Postgres
POSTGRES_USER=subtitle
POSTGRES_PASSWORD=subtitle
POSTGRES_DB=subtitle_app

# JWT
JWT_SECRET=change_me_in_production

# S3 / MinIO (dev uses MinIO defaults)
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=subtitle-videos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Internal service auth
INTERNAL_SECRET=internal_secret_change_me

# Transcriber
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
